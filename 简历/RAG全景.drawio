业务系统里的哪类资料&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;kb_version&quot;: &quot;...&quot;,&amp;nbsp; #&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;知识库版本&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;strike&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;dataset_id&quot;: &quot;default&quot;,&lt;/strike&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;visibility&quot;: &quot;internal&quot;,&amp;nbsp; # 可见级别，公开/内部/敏感/机密&lt;/div&gt;&lt;div&gt;&lt;strike&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;allowed_roles&quot;: [&quot;employee&quot;],&amp;nbsp; # 角色信息&lt;/strike&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;file_path&quot;: &quot;...&quot;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;file_name&quot;: &quot;...&quot;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;file_type&quot;: &quot;.pdf&quot;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;doc_id&quot;: &quot;...&quot;,&amp;nbsp; # 文档指纹&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;page_index&quot;: 0,&amp;nbsp; # 数据页&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;content_type&quot;: &quot;text&quot;,&amp;nbsp; # 普通都是text，表格是table-row&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;embedding_model_version&quot;: &quot;bge-m3-local-v1&quot;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;chunk_schema_version&quot;: &quot;parent_child_v1&quot;,&lt;/div&gt;&lt;/blockquote&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;" vertex="1">
